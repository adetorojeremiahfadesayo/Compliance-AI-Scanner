# Frontend build-time configuration (Vite). Copy to .env.local to override.
#
# By default the app calls the backend same-origin at /api and /ws, which works
# with the dev proxy (vite.config.js) and the production nginx proxy (nginx.conf).
# Set these only when the API is hosted on a different origin than the frontend.
#
# VITE_API_BASE=https://api.example.com/api
# VITE_WS_BASE=wss://api.example.com/ws/analysis
#
# Dev-only: point the Vite proxy at a non-default backend address.
# VITE_DEV_BACKEND=http://localhost:8000
