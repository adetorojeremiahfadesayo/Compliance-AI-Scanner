DASHSCOPE_API_KEY=your-qwen-cloud-api-key
GITHUB_TOKEN=your-github-token-optional
# Optional shared access token. When set, the frontend must send it as the
# X-API-Token header on every API call (see frontend/.env.example). Leave
# blank for local dev / a fully public demo deployment.
API_ACCESS_TOKEN=
DATABASE_URL=sqlite:///./compliance_autopilot.db
QWEN_MAX_MODEL=qwen3.7-max
QWEN_PLUS_MODEL=qwen3.7-plus
QWEN_TURBO_MODEL=qwen3.6-flash
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
